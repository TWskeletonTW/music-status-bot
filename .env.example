# ── 複製本檔為 .env，填入真實值後使用。.env 不可上傳 GitHub ──

# Discord 機器人 Token（必填）
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# 限定使用的伺服器 ID。私人機器人建議填寫。
DISCORD_GUILD_ID=YOUR_GUILD_ID_HERE

# 斜線指令同步模式：guild / global / off
# guild：只同步到 DISCORD_GUILD_ID，適合私人或測試用機器人。
# global：同步成全域指令，適合公開機器人。
# off：完全不自動同步。
COMMAND_SYNC_MODE=guild

# 是否在啟動時清掉舊的全域指令。通常保持 false；
# 只有從全域指令改成 guild 指令、需要清舊指令時才暫時改 true，跑一次後改回 false。
CLEAR_GLOBAL_COMMANDS_ON_START=false

# 權限設定。預設只有 Bot owner、管理員、具管理伺服器權限者可操作。
# 多個 ID 用逗號或空白分隔。
AUTHORIZED_USER_IDS=
AUTHORIZED_ROLE_IDS=

# 是否允許所有伺服器成員操作。公開伺服器不建議開啟。
ALLOW_EVERYONE_CONTROL=false

# 面板狀態檔，用來讓狀態面板在 Bot 重開後恢復。
PANEL_STATE_FILE=panel_state.json

# 音訊輸入裝置名稱，例如：CABLE Output (VB-Audio Virtual Cable)
MEDIA_INPUT_NAME=CABLE Output (VB-Audio Virtual Cable)

# Discord 語音建議固定 48000 Hz、2 聲道、960 blocksize。
AUDIO_SAMPLERATE=48000
AUDIO_CHANNELS=2
AUDIO_BLOCKSIZE=960

# 音訊佇列大小。越大越穩但延遲增加；越小越即時但容易掉幀。
AUDIO_QUEUE_SIZE=20

# 音訊緩衝等待秒數。若偶爾爆音或斷音，可以試 0.03。
AUDIO_BUFFER_TIMEOUT_SECONDS=0.02

# 歌詞提前顯示秒數。正數 = 提前；負數 = 延後。
LYRIC_ADVANCE_SECONDS=2.0

# 歌詞額外時間偏移秒數，會與 LYRIC_ADVANCE_SECONDS 相加。
LYRICS_TIME_OFFSET_SECONDS=0.0

# 歌詞自動套用的信心門檻。數值越高越保守，低於門檻時保留候選讓使用者手動選。
LYRICS_AUTO_ACCEPT_SCORE=28.0

# 歌詞手動記憶檔與其上限（超過依 updated_at 淘汰最舊）。
LYRICS_OVERRIDE_FILE=lyrics_overrides.json
LYRICS_OVERRIDE_MAX_ENTRIES=1000

# 面板最短更新間隔秒數。建議 5 秒，避免過度編輯訊息。
PANEL_UPDATE_INTERVAL_SECONDS=5.0

# 歌詞快取上限
MAX_LYRIC_CACHE=10

# 媒體資訊刷新頻率秒數
MEDIA_REFRESH_SECONDS=1.0

# 狀態列刷新頻率秒數
PRESENCE_REFRESH_SECONDS=10.0

# 讀取 Windows 媒體資訊 timeout 秒數
MEDIA_STATE_TIMEOUT_SECONDS=5.0

# 讀取 Windows 媒體資訊失敗時的重試次數與每次重試前等待秒數
MEDIA_STATE_RETRY_COUNT=3
MEDIA_STATE_RETRY_DELAY_SECONDS=0.3

# LRCLIB /get 短重試設定
LRCLIB_GET_RETRY_COUNT=1
LRCLIB_GET_RETRY_DELAY_SECONDS=0.5
